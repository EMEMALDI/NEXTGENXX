    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
